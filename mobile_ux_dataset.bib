@inproceedings{kumar2020notifications,
  title = {Push Notification Overload: Effects on User Stress (Short Paper)},
  author = {Kumar, Rajesh and Thompson, Sarah},
  booktitle = {Workshop on Mobile User Experience},
  year = {2020},
  pages = {12--15},
  keywords = {push notifications, user stress, mobile apps},
  note = {Conference Paper. NEAR-DUPLICATE: Workshop version of paper 3.},
  abstract = {This preliminary study examines push notification effects on user stress. We found that excessive notifications increase stress and lead to app uninstallation. Full results will be presented in an extended conference paper. This workshop paper shares early findings from ongoing research.}
}

@article{anderson2019onboarding,
  title = {Mobile App Onboarding: Why First Impressions Matter},
  author = {Anderson, Emily and Martinez, Carlos and Singh, Priya},
  journal = {International Journal of Human-Computer Interaction},
  year = {2019},
  volume = {35},
  number = {12},
  pages = {1045--1062},
  keywords = {mobile apps, onboarding, first use experience},
  note = {Journal Article. NEAR-DUPLICATE: Extended version of paper 4 with additional author.},
  abstract = {Building on our 2018 work, this extended study analyzes mobile app onboarding across 200 applications with 500 participants. We confirm that clear onboarding improves retention and expand our findings with longitudinal data. New contributions include industry-specific onboarding patterns and A/B testing results. This journal version provides comprehensive analysis beyond the earlier conference publication.}
}
